  "metadata": {
    "source_count": 12,
    "sources": [
      "商工会議所公式サンプル（3Q_*系: 6ファイル）",
      "市販問題集系（3級_*系: 6ファイル）"
    ],
    "exam_structure": {
      "第1問": {
        "配点": "45点（15問×3点）",
        "形式": "仕訳問題。取引文を読み、勘定科目ア～カから選択して仕訳",
        "問題数": "15問/回",
        "特徴": "勘定科目は設問ごとに6つ提示。消費税は指示された問題のみ"
      },
      "第2問": {
        "配点": "20点",
        "形式": "勘定記入・補助簿・伝票。⑴⑵の2問構成が多い",
        "パターン": [
          "勘定記入（T勘定の空欄補充）",
          "補助簿の選択（どの補助簿に記入されるか）",
          "固定資産台帳からの勘定記入",
          "商品売買の勘定記入（3分法）",
          "前払・前受の勘定記入と決算整理"
        ]
      },
      "第3問": {
        "配点": "35点",
        "形式": "精算表作成 or 財務諸表（B/S・P/L）作成",
        "特徴": "決算整理前残高試算表 + 決算整理事項 → 精算表 or B/S・P/L"
      }
    }
  },
